{
    auto_https off
    debug
}

{$LISTEN_DOMAIN} {
    tls /certs/_wildcard.{$LISTEN_DOMAIN}.pem /certs/_wildcard.{$LISTEN_DOMAIN}-key.pem
    reverse_proxy backend:80
}

{$LISTEN_DOMAIN}:5173 {
    tls /certs/_wildcard.{$LISTEN_DOMAIN}.pem /certs/_wildcard.{$LISTEN_DOMAIN}-key.pem
    reverse_proxy frontend:5173
}

db.{$LISTEN_DOMAIN} {
    tls /certs/_wildcard.{$LISTEN_DOMAIN}.pem /certs/_wildcard.{$LISTEN_DOMAIN}-key.pem
    reverse_proxy adminer:8080
}

mail.{$LISTEN_DOMAIN} {
    tls /certs/_wildcard.{$LISTEN_DOMAIN}.pem /certs/_wildcard.{$LISTEN_DOMAIN}-key.pem
    reverse_proxy mailpit:8025
}
